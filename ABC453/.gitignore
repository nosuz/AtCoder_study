# =========================
# IDE
# =========================
.idea/
.vscode/
*.iml

# =========================
# OS
# =========================
.DS_Store

# =========================
# example cache
# =========================
cache/
examples/

# <<< gitignore:java >>>
# =========================
# Build / Gradle
# =========================
.gradle/
build/
out/
bin/

# =========================
# Generated Java sources
# （setup-java.py が自動生成）
# =========================
src/main/java/abc453/*.java
src/test/java/abc453/*Test.java

# =========================
# Allow commit for solved problems
# =========================
#
# --- Java ---
# 解けた問題は、以下の行のコメント (#) を外してください
# !src/main/java/abc453/A.java
# !src/test/java/abc453/ATest.java
# !src/main/java/abc453/B.java
# !src/test/java/abc453/BTest.java
# !src/main/java/abc453/C.java
# !src/test/java/abc453/CTest.java
# !src/main/java/abc453/D.java
# !src/test/java/abc453/DTest.java
# !src/main/java/abc453/E.java
# !src/test/java/abc453/ETest.java
# !src/main/java/abc453/F.java
# !src/test/java/abc453/FTest.java

# <<< gitignore:python >>>
# =========================
# Generated Python sources
# （setup-python.py が自動生成）
# =========================
*.py
tests/*.py
# pytest.ini
__pycache__/
.pytest_cache/
*.pyc

# --- Python ---
# 解けた問題は、以下の行のコメント (#) を外してください
!A.py
!tests/test_a.py
!B.py
!tests/test_b.py
!C.py
!tests/test_c.py
# !D.py
# !tests/test_d.py
# !E.py
# !tests/test_e.py
# !F.py
# !tests/test_f.py
